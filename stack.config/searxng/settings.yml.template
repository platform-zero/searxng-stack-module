use_default_settings: true

general:
  debug: false
  instance_name: "Webservices Search"

search:
  safe_search: 1
  autocomplete: ""
  formats:
  - html
  - json

server:
  secret_key: "{{SEARXNG_SECRET}}"
  limiter: false
  image_proxy: true
  bind_address: "0.0.0.0"
  port: 8080
  base_url: "https://websearch.{{DOMAIN}}/"

ui:
  static_use_hash: true
